OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

# Shopier: webhook doğrulama (biri zorunlu)
# Basit: Shopier bildiriminde header X-Sanri-Webhook-Secret ile aynı değer
SHOPIER_WEBHOOK_SECRET=your_long_random_secret
# Alternatif: HMAC — Shopier-Signature veya X-Shopier-Signature (body ile)
# SHOPIER_WEBHOOK_TOKEN=shared_secret_for_hmac

# Opsiyonel: Shopier product_id -> content_id JSON (yoksa kod içi varsayılan harita)
# SHOPIER_PRODUCT_MAP={"45812975":"role_unlock","45833965":"kod_egitmeni"}

# Shopier Personal Access Token — webhook yetersizse siparişi API ile doğrulamak için (önerilir)
SHOPIER_PAT=
# Varsayılan: https://api.shopier.com/v1
# SHOPIER_API_BASE=https://api.shopier.com/v1

# POST /shopier/register-webhook için callback (Shopier’e bildirilecek URL)
# Tam URL veya sadece API kökü:
# SHOPIER_WEBHOOK_CALLBACK_URL=https://xxx.up.railway.app/shopier/webhook
# SANRI_API_PUBLIC_URL=https://xxx.up.railway.app

# Havale / EFT — desteklenen content_id: app.routes.bank_transfer.BANK_PRODUCT_CATALOG anahtarları
# (örn. role_unlock, okuma_23, …)
#
# Havale / EFT (bank_transfer_requests) — IBAN + alıcı + banka zorunlu (sanri-api servisinde)
# BANK_TRANSFER_IBAN=TR00 0000 0000 0000 0000 0000 00   (veya BANK_IBAN)
# BANK_TRANSFER_RECIPIENT_NAME=Şirket / İsim   (veya BANK_TRANSFER_NAME / BANK_ACCOUNT_NAME)
# BANK_TRANSFER_BANK_NAME=Banka adı            (veya BANK_TRANSFER_BANK / BANK_NAME)
# BANK_TRANSFER_NOTE=Ödeme açıklamasına sana verilen kodu yaz  (boşsa varsayılan metin)
# BANK_TRANSFER_IBAN_LABEL=SANRI — TRY
# BANK_TRANSFER_MAX_RECEIPT_BYTES=1500000