OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

# Shopier: webhook doğrulama (biri zorunlu)
# Basit: Shopier bildiriminde header X-Sanri-Webhook-Secret ile aynı değer
SHOPIER_WEBHOOK_SECRET=your_long_random_secret
# Alternatif: HMAC — Shopier-Signature veya X-Shopier-Signature (body ile)
# SHOPIER_WEBHOOK_TOKEN=shared_secret_for_hmac

# Opsiyonel: Shopier product_id -> content_id JSON (yoksa kod içi varsayılan harita)
# SHOPIER_PRODUCT_MAP={"45812975":"role_unlock","45833965":"kod_egitmeni"}

# Shopier Personal Access Token — webhook yetersizse siparişi API ile doğrulamak için (önerilir)
SHOPIER_PAT=
# Varsayılan: https://api.shopier.com/v1
# SHOPIER_API_BASE=https://api.shopier.com/v1